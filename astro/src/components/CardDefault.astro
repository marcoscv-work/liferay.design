---
// Port of molecules/CardDefault — image card with grayscale->color on hover,
// an overlapping avatar or icon, title and subtitle.
import Icon from './Icon.astro'

interface Props {
	imageURL?: string
	icon?: string
	title?: string
	subtitle?: string
	link: string
	avatarImage?: boolean
	avatarImageURL?: string
	aspectRatio?: '4:3' | '16:9'
}
const {
	imageURL,
	icon,
	title,
	subtitle,
	link,
	avatarImage,
	avatarImageURL,
	aspectRatio = '4:3',
} = Astro.props
const pad = aspectRatio === '16:9' ? '56.25%' : '75%'
---

<a class="card-link" href={link}>
	<article class="card">
		<div class="media" style={`--ratio:${pad}`}>
			<img class="shadow" alt="" src={imageURL} loading="lazy" />
			<img class="cover" alt={'image for ' + title} src={imageURL} loading="lazy" />
		</div>
		<div class="body">
			<div class="badge">
				{
					avatarImage ? (
						<img class="avatar" alt="" src={avatarImageURL} loading="lazy" />
					) : (
						icon && <Icon name={icon} color="var(--c-white)" size="2rem" />
					)
				}
			</div>
			<h3 class="title">{title}</h3>
			<p class="subtitle">{subtitle}</p>
		</div>
	</article>
</a>

<style>
	.card-link { display: block; height: 100%; }
	.card {
		display: flex;
		height: 100%;
		flex-direction: column;
		box-shadow: var(--elev-1);
		border-radius: 1rem;
		overflow: hidden;
		transform: translateY(0);
		transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
	}
	.card-link:hover .card {
		box-shadow: var(--elev-2);
		transform: translateY(-0.5em);
	}
	.media {
		position: relative;
		padding-bottom: var(--ratio);
		overflow: hidden;
	}
	.media img {
		position: absolute;
		inset: 0;
		height: 100%;
		width: 100%;
		object-fit: cover;
		filter: grayscale(1);
		transition: filter 0.2s ease-in-out;
	}
	.media .shadow { filter: blur(32px); opacity: 0; }
	.card-link:hover .media .cover { filter: grayscale(0); }
	.body {
		padding: 1rem 2rem 3rem;
		background: var(--c-main-l1);
		flex-grow: 1;
	}
	.badge {
		display: flex;
		align-items: center;
		justify-content: center;
		height: 64px;
		width: 64px;
		border-radius: 50%;
		background: var(--c-main);
		margin-top: -48px;
		margin-bottom: 1rem;
		color: var(--c-white);
	}
	.avatar { height: 64px; width: 64px; border-radius: 50%; object-fit: cover; }
	.title {
		color: var(--c-white);
		margin-bottom: 2rem;
		line-height: 1.3;
		font-size: 1.5rem;
	}
	.subtitle { color: var(--c-main-l5); font-size: 1.2rem; }
</style>
