---
import BaseLayout from '@layouts/BaseLayout.astro'
import Container from '@components/Container.astro'
import Footer from '@components/Footer.astro'

const cards = [
	{ title: 'Get Started', text: 'An onboarding section as an introduction to the project, its objectives and proposals', to: '/lexicon/get-started' },
	{ title: 'Foundations', text: 'The basic principles and guidelines that lay on the core of the pattern library.', to: '/lexicon/foundations/grid' },
	{ title: 'Components', text: 'The list of components and patterns that configure the building blocks of the Lexicon system', to: '/lexicon/core-components/alerts' },
	{ title: 'Resources', text: 'A set of tools, links and downloads to learn Lexicon and use it in your projects', to: '/lexicon/resources' },
]
---

<BaseLayout
	pageTitle="Liferay Lexicon | An Experience Language for Crafting Beautiful UI"
	description="Lexicon is a design language that provides a common framework for building interfaces within the Liferay product ecosystem."
	bodyClass="lexicon-doc"
>
	<main id="main-content" tabindex="-1">
		<section class="lx-banner">
			<Container>
				<h1>Lexicon</h1>
				<p>An Experience Language for Crafting Beautiful UI</p>
				<a class="lx-cta" href="/lexicon/get-started">Get Started</a>
			</Container>
		</section>

		<section class="lx-explore">
			<Container heading="Explore Lexicon">
				<div class="grid-two">
					{
						cards.map(c => (
							<a class="lx-card" href={c.to}>
								<h3>{c.title}</h3>
								<p>{c.text}</p>
								<span class="more">Learn More →</span>
							</a>
						))
					}
				</div>
			</Container>
		</section>

		<section class="lx-clay">
			<Container>
				<a class="lx-card dark" href="https://clayui.com">
					<h3>Clay</h3>
					<p>A web implementation of the Lexicon Design System.</p>
					<span class="more">Visit Clay →</span>
				</a>
			</Container>
		</section>
	</main>
	<Footer background="#30313f" />
</BaseLayout>

<style>
	main { background: #fff; }
	.lx-banner {
		background: url(/images/lexicon/home/patternbg.svg) center fixed, #0b5fff;
		color: #fff;
		padding: 4rem 0 6rem;
	}
	.lx-banner h1 { font-size: 5rem; margin: 0; border-bottom: 4px solid #5fe5c1; display: inline-block; }
	.lx-banner p { font-size: 1.4rem; margin: 1rem 0 2rem; }
	.lx-cta {
		display: inline-block; background: #fff; color: var(--c-primary);
		padding: 0.75rem 2rem; border-radius: 0.4rem; font-weight: var(--fw-heavy);
	}
	.lx-explore { background: #f7f7f9; color: var(--c-main); }
	.lx-explore :global(.container-heading) { color: var(--c-main); }
	.lx-card {
		display: block; background: #fff; border-radius: 1rem; padding: 2rem;
		box-shadow: var(--elev-1); color: var(--c-main); height: 100%;
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.lx-card:hover { transform: translateY(-0.5rem); box-shadow: var(--elev-2); }
	.lx-card h3 { color: var(--c-main); margin-bottom: 0.5rem; }
	.lx-card p { color: var(--c-main-l3); }
	.lx-card .more { color: var(--c-primary); font-weight: var(--fw-heavy); }
	.lx-clay { background: #fff; padding: 4rem 0; }
	.lx-card.dark { background: #30313f; color: #fff; }
	.lx-card.dark h3 { color: #fff; }
	.lx-card.dark p { color: var(--c-main-l5); }
</style>
