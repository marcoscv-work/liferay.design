---
// Port of molecules/ColorSwatch — a color card: filled block + title + the
// HEX/RGB/HSL (and optional CMYK/PMS) value rows.
const { hex, rgb, hsl, cmyk, pms, title, smallText, name, contrasted } = Astro.props
const bg = hex ? `#${hex}` : name ? `var(--c-${name})` : 'transparent'
const fields = [
	hex && { label: 'HEX', value: hex },
	rgb && { label: 'RGB', value: rgb },
	hsl && { label: 'HSL', value: hsl },
	cmyk && { label: 'CMYK', value: cmyk },
	pms && { label: 'PMS', value: pms },
].filter(Boolean) as { label: string; value: string }[]
---

<div class="swatch">
	<div class="swatch-color" style={`background:${bg}`}>
		{(contrasted === 'white' || contrasted === 'both') && <span class="contrast">3:1</span>}
		{(contrasted === 'black' || contrasted === 'both') && <span class="contrast black">3:1</span>}
	</div>
	<div class="swatch-body">
		<p class="swatch-title">{title}{smallText && <small>{smallText}</small>}</p>
		{
			fields.map(f => (
				<div class="cf">
					<span class="cf-label">{f.label}</span>
					<span class="cf-value">{f.value}</span>
				</div>
			))
		}
	</div>
</div>

<style>
	.swatch {
		display: flex;
		flex-direction: column;
		box-shadow: var(--elev-1);
		border-radius: 0.4rem;
		overflow: hidden;
		background: #fff;
	}
	.swatch-color {
		position: relative;
		width: 100%;
		padding-bottom: 56.25%;
		border-bottom: 1px solid var(--c-main-l8);
	}
	.contrast {
		position: absolute;
		top: 0.5rem;
		left: 0.5rem;
		color: #fff;
		border: 1px solid #fff;
		border-radius: 50%;
		font-size: 10px;
		width: 24px;
		height: 24px;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.contrast.black { color: #000; border-color: #000; left: 2.25rem; }
	.swatch-body { display: flex; flex-direction: column; padding: 1rem; }
	.swatch-title { font-weight: 800; margin: 0 0 0.5rem; color: var(--c-main); }
	.swatch-title small { display: block; font-weight: 400; color: var(--c-main-l3); }
	.cf { display: flex; gap: 0.5rem; font-size: 12px; line-height: 1.8; }
	.cf-label { color: var(--c-main-l3); font-weight: 700; min-width: 3em; }
	.cf-value { color: var(--c-main-l2); font-family: var(--font-mono); }
</style>
