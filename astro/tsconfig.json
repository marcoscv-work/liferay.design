{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"baseUrl": ".",
		"paths": {
			"@components/*": ["src/components/*"],
			"@layouts/*": ["src/layouts/*"],
			"@lib/*": ["src/lib/*"],
			"@styles/*": ["src/styles/*"]
		}
	},
	"include": [".astro/types.d.ts", "src/**/*"],
	"exclude": ["dist"]
}
